{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Commerce": "Data Source=App_Data/commerce-demo.db"
  },
  "Cache": {
    "Provider": "InMemory"
  },
  "Messaging": {
    "Provider": "InProcess",
    "Topic": "catalog-events"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
